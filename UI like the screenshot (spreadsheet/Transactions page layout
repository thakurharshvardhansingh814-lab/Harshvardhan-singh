<!DOCTYPE html>
<html>
<head>
<title>Transactions</title>

<style>

body{
font-family:Arial;
background:#f5f5f5;
}

.container{
width:850px;
margin:60px auto;
padding:30px;
background:white;
border:2px solid black;
}

/* top menu */

.top{
display:flex;
justify-content:space-between;
margin-bottom:20px;
font-weight:bold;
}

.top a{
color:blue;
text-decoration:underline;
}

/* main layout */

.main{
display:flex;
justify-content:space-between;
}

/* transaction options */

.options{
line-height:40px;
font-weight:bold;
}

.options a{
display:block;
color:black;
text-decoration:none;
}

.options a:hover{
color:blue;
}

/* note section */

.note{
width:350px;
font-size:14px;
}

/* logout */

.logout{
margin-top:20px;
}

.logout button{
padding:8px 20px;
background:#3d85c6;
color:white;
border:none;
border-radius:5px;
cursor:pointer;
}

.logout button:hover{
background:#2c6aa0;
}

</style>

</head>

<body>

<div class="container">

<div class="top">
<a href="#">Chart</a>
<div>Transactions</div>
<a href="#">Home</a>
</div>

<div class="main">

<div class="options">
<a href="#">Is Book Available?</a>
<a href="#">Issue Book?</a>
<a href="#">Return Book?</a>
<a href="#">Pay Fine?</a>

<div class="logout">
<button>Log Out</button>
</div>
</div>

<div class="note">
<b>Note:</b><br><br>

If logged in as <b>Admin</b> – Home will take you to
<b>Admin Home Page</b>.<br><br>

If logged in as <b>User</b> – Home will take you to
<b>User Home Page</b>.
</div>

</div>

</div>

</body>
</html>
