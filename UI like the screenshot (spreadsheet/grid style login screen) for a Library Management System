<!DOCTYPE html>
<html>
<head>
<title>Library Management System</title>

<style>

body{
    font-family: Arial;
    background:#f5f5f5;
}

/* sheet background */

.sheet{
    width:700px;
    margin:80px auto;
    padding:40px;
    background-image:
    linear-gradient(#dcdcdc 1px, transparent 1px),
    linear-gradient(90deg,#dcdcdc 1px, transparent 1px);
    background-size:60px 40px;
}

/* header links */

.top{
    display:flex;
    justify-content:space-between;
    margin-bottom:40px;
}

.top a{
    color:#1a73e8;
    text-decoration:underline;
}

/* title */

.title{
    text-align:center;
    font-weight:bold;
    margin-bottom:30px;
}

/* form rows */

.row{
    display:flex;
    align-items:center;
    margin:15px 0;
}

.row label{
    width:120px;
    font-weight:bold;
}

.row input{
    width:300px;
    padding:8px;
    border:3px solid black;
}

/* buttons */

.buttons{
    margin-top:25px;
    display:flex;
    justify-content:center;
    gap:40px;
}

button{
    width:140px;
    padding:10px;
    font-size:16px;
    border:none;
    border-radius:8px;
    color:white;
    background:linear-gradient(#79aee3,#3d85c6);
    cursor:pointer;
}

button:hover{
    opacity:0.9;
}

/* bottom line */

.line{
    margin-top:40px;
    border-top:3px solid black;
}

</style>
</head>

<body>

<div class="sheet">

<div class="top">
<a href="#">Chart</a>
<a href="#">Back</a>
</div>

<div class="title">
Library Management System
</div>

<form>

<div class="row">
<label>User ID</label>
<input type="text" value="user">
</div>

<div class="row">
<label>Password</label>
<input type="password" value="user">
</div>

<div class="buttons">
<button type="reset">Cancel</button>
<button type="submit">Login</button>
</div>

</form>

<div class="line"></div>

</div>

</body>
</html>
