<!DOCTYPE html>
<html>
<head>
<title>Transactions - Book Availability</title>

<style>

body{
font-family: Arial;
background:#f5f5f5;
}

.container{
width:900px;
margin:60px auto;
padding:25px;
border:2px solid black;
background:white;
}

/* top navigation */

.top{
display:flex;
justify-content:space-between;
font-weight:bold;
margin-bottom:25px;
}

.top a{
color:blue;
text-decoration:underline;
}

/* main layout */

.main{
display:flex;
justify-content:space-between;
}

/* left menu */

.menu{
width:200px;
line-height:40px;
font-weight:bold;
}

.menu a{
display:block;
text-decoration:none;
color:black;
}

.menu a:hover{
color:blue;
}

/* center form */

.form-section{
width:320px;
}

.form-section h3{
margin-bottom:15px;
}

.form-row{
margin-bottom:12px;
}

.form-row label{
display:block;
margin-bottom:5px;
}

select{
width:100%;
padding:6px;
}

/* note section */

.note{
width:250px;
font-size:14px;
}

/* logout */

.logout{
margin-top:25px;
text-align:center;
}

.logout button{
padding:8px 25px;
background:#3d85c6;
color:white;
border:none;
border-radius:5px;
cursor:pointer;
}

.logout button:hover{
background:#2c6aa0;
}

</style>

</head>

<body>

<div class="container">

<div class="top">
<a href="#">Chart</a>
<div>Transactions</div>
<a href="#">Home</a>
</div>

<div class="main">

<!-- Left Menu -->

<div class="menu">
<a href="#">Is book available?</a>
<a href="#">Issue book?</a>
<a href="#">Return book?</a>
<a href="#">Pay Fine?</a>
</div>

<!-- Book Availability Form -->

<div class="form-section">

<h3>Book Availability</h3>

<div class="form-row">
<label>Enter Book Name</label>
<select>
<option>Select Book</option>
<option>Science</option>
<option>Economics</option>
<option>Fiction</option>
<option>Children</option>
<option>Personal Development</option>
</select>
</div>

<div class="form-row">
<label>Enter Author</label>
<select>
<option>Select Author</option>
<option>Author 1</option>
<option>Author 2</option>
<option>Author 3</option>
</select>
</div>

</div>

<!-- Note Section -->

<div class="note">

<b>Note:</b><br><br>

If logged in as <b>Admin</b> – Home will take to
<b>Admin Home Page</b>.<br><br>

If logged in as <b>User</b> – Home will take to
<b>User Home Page</b>.

</div>

</div>

<div class="logout">
<button>Log Out</button>
</div>

</div>

</body>
</html>
