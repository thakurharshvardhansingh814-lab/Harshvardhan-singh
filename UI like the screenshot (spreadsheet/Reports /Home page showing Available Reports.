<!DOCTYPE html>
<html>
<head>
<title>Reports</title>

<style>

body{
font-family:Arial;
background:#f5f5f5;
}

.container{
width:900px;
margin:60px auto;
padding:25px;
border:2px solid black;
background:white;
}

/* top bar */

.top{
display:flex;
justify-content:space-between;
font-weight:bold;
margin-bottom:20px;
}

.top a{
color:blue;
text-decoration:underline;
}

/* layout */

.main{
display:flex;
gap:40px;
}

/* report list */

.reports{
flex:1;
}

.reports h3{
margin-bottom:15px;
}

.reports a{
display:block;
margin-bottom:10px;
text-decoration:none;
color:black;
font-weight:bold;
}

.reports a:hover{
color:blue;
}

/* note */

.note{
width:260px;
font-size:14px;
}

/* logout */

.logout{
margin-top:20px;
text-align:left;
}

button{
padding:8px 20px;
background:#3d85c6;
color:white;
border:none;
border-radius:5px;
cursor:pointer;
}

button:hover{
background:#2c6aa0;
}

</style>
</head>

<body>

<div class="container">

<div class="top">
<a href="#">Chart</a>
<a href="#">Home</a>
</div>

<div class="main">

<!-- reports -->

<div class="reports">

<h3>Available Reports</h3>

<a href="#">Master List of Books</a>
<a href="#">Master List of Movies</a>
<a href="#">Master List of Memberships</a>
<a href="#">Active Issues</a>
<a href="#">Overdue Returns</a>
<a href="#">Pending Issue Requests</a>

<div class="logout">
<button>Log Out</button>
</div>

</div>

<!-- note -->

<div class="note">

<b>Note:</b><br><br>

If logged in as <b>Admin</b> – Home will take to  
<b>Admin Home Page</b>.<br><br>

If logged in as <b>User</b> – Home will take to  
<b>User Home Page</b>.

</div>

</div>

</div>

</body>
</html>
