<!DOCTYPE html>
<html>
<head>
<title>Transactions</title>

<style>

body{
font-family:Arial;
background:#f5f5f5;
}

.container{
width:1000px;
margin:50px auto;
padding:20px;
border:2px solid black;
background:white;
}

/* top menu */

.top{
display:flex;
justify-content:space-between;
font-weight:bold;
margin-bottom:20px;
}

.top a{
color:blue;
text-decoration:underline;
}

/* layout */

.main{
display:flex;
gap:20px;
}

/* left menu */

.menu{
width:180px;
line-height:35px;
font-weight:bold;
}

.menu a{
display:block;
text-decoration:none;
color:black;
}

.menu a:hover{
color:blue;
}

/* table section */

.table-section{
flex:1;
}

table{
width:100%;
border-collapse:collapse;
margin-top:10px;
}

th, td{
border:1px solid black;
padding:8px;
text-align:center;
}

th{
background:#eee;
}

/* note */

.note{
width:250px;
font-size:14px;
}

/* logout */

.logout{
margin-top:20px;
text-align:center;
}

button{
padding:8px 20px;
background:#3d85c6;
color:white;
border:none;
border-radius:5px;
cursor:pointer;
}

button:hover{
background:#2c6aa0;
}

</style>
</head>

<body>

<div class="container">

<div class="top">
