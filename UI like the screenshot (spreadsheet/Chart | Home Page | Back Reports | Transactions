<!DOCTYPE html>
<html>
<head>
<title>Home Page</title>

<style>

body{
font-family: Arial;
background:#f5f5f5;
}

.container{
width:850px;
margin:60px auto;
padding:25px;
background:white;
border:2px solid #000;
}

/* top bar */

.top{
display:flex;
justify-content:space-between;
margin-bottom:15px;
}

.top a{
color:blue;
text-decoration:underline;
font-weight:bold;
}

/* title */

.title{
text-align:center;
font-size:22px;
font-weight:bold;
margin-bottom:20px;
}

/* menu */

.menu{
display:flex;
gap:60px;
font-weight:bold;
margin-bottom:20px;
}

/* table */

table{
width:100%;
border-collapse:collapse;
}

th, td{
border:1px solid black;
padding:10px;
text-align:center;
}

th{
background:#eee;
}

/* logout */

.logout{
text-align:center;
margin-top:30px;
}

.logout button{
padding:10px 25px;
font-size:16px;
background:#3d85c6;
color:white;
border:none;
border-radius:6px;
cursor:pointer;
}

.logout button:hover{
background:#2c6aa0;
}

</style>
</head>

<body>

<div class="container">

<div class="top">
<a href="#">Chart</a>
<a href="#">Back</a>
</div>

<div class="title">Home Page</div>

<div class="menu">
