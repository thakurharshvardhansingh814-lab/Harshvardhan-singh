<!DOCTYPE html>
<html>
<head>
<title>Pay Fine</title>

<style>

body{
font-family:Arial;
background:#f5f5f5;
}

.container{
width:1000px;
margin:50px auto;
padding:20px;
border:2px solid black;
background:white;
}

/* top bar */

.top{
display:flex;
justify-content:space-between;
font-weight:bold;
margin-bottom:20px;
}

.top a{
color:blue;
text-decoration:underline;
}

/* layout */

.main{
display:flex;
gap:30px;
}

/* left menu */

.menu{
width:180px;
line-height:35px;
font-weight:bold;
}

.menu a{
display:block;
text-decoration:none;
color:black;
}

.menu a:hover{
color:blue;
}

/* form section */

.form-section{
flex:1;
}

.form-row{
margin-bottom:12px;
}

label{
display:block;
font-weight:bold;
margin-bottom:4px;
}

input, textarea{
width:100%;
padding:6px;
}

textarea{
height:60px;
}

/* note */

.note{
width:260px;
font-size:14px;
}

/* logout */

.logout{
margin-top:20px;
text-align:center;
}

button{
padding:8px 20px;
background:#3d85c6;
color:white;
border:none;
border-radius:5px;
cursor:pointer;
}

button:hover{
background:#2c6aa0;
}

</style>
</head>

<body>

<div class="container">

<div class="top">
<a href="#">Chart</a>
<div>Transactions</div>
<a href="#">Home</a>
</div>

<div class="main">

<!-- left menu -->

<div class="menu">
<a href="#">Is book available?</a>
<a href="#">Issue book?</a>
<a href="#">Return book?</a>
<a href="#">Pay Fine?</a>
</div>

<!-- pay fine form -->

<div class="form-section">

<h3>Pay Fine</h3>

<div class="form-row">
<label>Enter Book Name</label>
<input type="text">
</div>

<div class="form-row">
<label>Enter Author</label>
<input type="text">
</div>

<div class="form-row">
<label>Serial No</label>
<input type="text">
</div>

<div class="form-row">
<label>Issue Date</label>
<input type="date">
</div>

<div class="form-row">
<label>Return Date</label>
<input type="date">
</div>

<div class="form-row">
<label>Actual Return Date</label>
<input type="date">
</div>

<div class="form-row">
<label>Fine Calculated</label>
<input type="text" value="0">
</div>

<div class="form-row">
<label>
<input type="checkbox"> Fine Paid
</label>
</div>

<div class="form-row">
<label>Remarks (Optional)</label>
<textarea></textarea>
</div>

</div>

<!-- note -->

<div class="note">

<b>Note:</b><br><br>

If logged in as <b>Admin</b> – Home will take to  
<b>Admin Home Page</b>.<br><br>

If logged in as <b>User</b> – Home will take to  
<b>User Home Page</b>.

</div>

</div>

<div class="logout">
<button>Log Out</button>
</div>

</div>

</body>
</html>
