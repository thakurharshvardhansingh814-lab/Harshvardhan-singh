<!DOCTYPE html>
<html>
<head>
<title>Library Management System</title>

<style>

body{
    font-family: Arial, sans-serif;
    background:#f2f2f2;
}

/* main container */

.container{
    width:600px;
    margin:120px auto;
    background:white;
    padding:40px;
    border:2px solid #333;
}

/* title */

h2{
    text-align:center;
    margin-bottom:30px;
}

/* form rows */

.form-row{
    display:flex;
    align-items:center;
    margin:15px 0;
}

label{
    width:120px;
    font-weight:bold;
}

input{
    flex:1;
    padding:8px;
    border:2px solid #333;
}

/* buttons */

.button-group{
    margin-top:30px;
    display:flex;
    justify-content:space-around;
}

button{
    width:140px;
    padding:10px;
    border:none;
    border-radius:6px;
    background:linear-gradient(#6fa8dc,#3d85c6);
    color:white;
    font-size:16px;
    cursor:pointer;
}

button:hover{
    opacity:0.9;
}

/* top links */

.top-links{
    display:flex;
    justify-content:space-between;
    margin-bottom:20px;
}

.top-links a{
    text-decoration:none;
    color:#1a73e8;
}

</style>
</head>

<body>

<div class="container">

<div class="top-links">
<a href="#">Chart</a>
<a href="#">Back</a>
</div>

<h2>Library Management System</h2>

<form>

<div class="form-row">
<label>User ID</label>
<input type="text" value="adm">
</div>

<div class="form-row">
<label>Password</label>
<input type="password" value="adm">
</div>

<div class="button-group">
<button type="reset">Cancel</button>
<button type="submit">Login</button>
</div>

</form>

</div>

</body>
</html>
